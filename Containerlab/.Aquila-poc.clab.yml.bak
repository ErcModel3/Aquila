name: Aquila

mgmt:
  network: aquila-mgmt
  ipv4-subnet: 192.168.10.0/24

topology:
  kinds:
    juniper_vjunosrouter:
      startup-config: ./config/junos-base.txt
      image: vrnetlab/juniper_vjunos-router:24.2R1-S2.5
      group: router
      labels:
        ansible-group: router
    linux:
      image: ubuntu:24.04
      dns:
        servers:
          - 1.1.1.1
          - 8.8.4.4
        
    probe-server:
    application-server:

  nodes:
    # Core switches
    core1:
      kind: juniper_vjunosrouter
      startup-config: ./configs/core1-config.txt
      mgmt-ipv4: 192.168.10.4
    core2:
      kind: juniper_vjunosrouter
      startup-config: ./configs/core2-config.txt
      mgmt-ipv4: 192.168.10.5
    core3:
      startup-config: ./configs/core3-config.txt
      kind: juniper_vjunosrouter
      mgmt-ipv4: 192.168.10.6
    
    # servers
    probe-core1:
      kind: linux
      mgmt-ipv4: 192.168.10.40
      group: server
      labels:
        ansible-group: servers
    probe-core2:
      kind: linux
      mgmt-ipv4: 192.168.10.50
      group: server
      labels:
        ansible-group: servers
    probe-core3:
      kind: linux
      mgmt-ipv4: 192.168.10.60
      group: server
      labels:
        ansible-group: servers
    
    stats-portal:
      kind: linux
      mgmt-ipv4: 192.168.10.100
      group: application-servers
      labels:
        ansible-group: application-servers

    stats-collector:
      kind: linux
      mgmt-ipv4: 192.168.10.101
      group: application-servers
      labels:
        ansible-group: application-servers

  links:
    # ISL Patching
    - endpoints: ["core1:xe-0/0/0", core2:xe-0/0/0]
    - endpoints: ["core1:xe-0/0/1", core3:xe-0/0/1]
    - endpoints: ["core2:xe-0/0/2", core3:xe-0/0/2]
    
    # Probe patching
    - endpoints: ["core1:xe-0/0/5", probe-core1:eth1"]
    - endpoints: ["core2:xe-0/0/5", probe-core2:eth1"]
    - endpoints: ["core3:xe-0/0/5", probe-core3:eth1"]
